---
interface Props {
  depth: 'essential' | 'applied' | 'technical' | 'research';
  size?: 'sm' | 'md' | 'lg';
}

const { depth, size = 'md' } = Astro.props;

const config = {
  essential: { emoji: '🟢', label: 'Essential', bg: 'bg-zro-green-light', text: 'text-zro-green-dark', border: 'border-zro-green' },
  applied: { emoji: '🔵', label: 'Applied', bg: 'bg-zro-blue-light', text: 'text-zro-blue-dark', border: 'border-zro-blue' },
  technical: { emoji: '🟣', label: 'Technical', bg: 'bg-zro-purple-light', text: 'text-zro-purple-dark', border: 'border-zro-purple' },
  research: { emoji: '🔴', label: 'Research', bg: 'bg-zro-red-light', text: 'text-zro-red-dark', border: 'border-zro-red' },
};

const c = config[depth];
const sizeClasses = {
  sm: 'text-xs px-2 py-0.5',
  md: 'text-sm px-3 py-1',
  lg: 'text-base px-4 py-1.5',
};
---

<span class:list={[
  "inline-flex items-center gap-1.5 rounded-full font-medium border",
  c.bg, c.text, c.border,
  sizeClasses[size]
]}>
  <span>{c.emoji}</span>
  <span>{c.label}</span>
</span>
