---
import Layout from '../../../layouts/Layout.astro';
import DepthBadge from '../../../components/DepthBadge.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('learn', ({ data }) => !data.draft);
  const topics = [...new Set(articles.map((article) => article.data.topic))];
  return topics.map((topic) => ({ params: { topic } }));
}

const { topic } = Astro.params;
const allArticles = await getCollection('learn', ({ data }) => !data.draft);
const topicArticles = allArticles
  .filter((article) => article.data.topic === topic)
  .sort((a, b) => {
    const order = { essential: 0, applied: 1, technical: 2, research: 3 };
    return order[a.data.depth] - order[b.data.depth];
  });

const topicTitle = topic?.replace(/-/g, ' ') ?? 'Topic';
---

<Layout title={`${topicTitle} — Learn — Zro2One`} description={`Explore ${topicTitle} across every depth level.`} canonical={`/learn/topic/${topic}`}>
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-24">
    <a href="/learn" class="inline-flex text-sm text-zro-blue hover:underline mb-6">← Back to all topics</a>
    <h1 class="text-4xl sm:text-5xl font-black text-zro-dark capitalize mb-3">{topicTitle}</h1>
    <p class="text-lg text-zro-gray mb-10">Progress from zero to frontier with a guided depth ladder.</p>

    <div class="space-y-4">
      {topicArticles.map((article) => (
        <a href={`/learn/${article.id}`} class="block rounded-xl border border-gray-200 p-5 hover:border-zro-blue transition-colors">
          <div class="flex flex-wrap items-center gap-3 mb-2">
            <DepthBadge depth={article.data.depth} size="sm" />
            <span class="text-sm text-zro-gray">{article.data.readTime} min read</span>
          </div>
          <h2 class="text-xl font-bold text-zro-dark">{article.data.title}</h2>
          <p class="text-zro-gray mt-1">{article.data.description}</p>
        </a>
      ))}
    </div>
  </section>
</Layout>
