---
import Layout from '../../layouts/Layout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import DepthBadge from '../../components/DepthBadge.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('learn', ({ data }) => !data.draft);
const articles = allArticles.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const depths = ['essential', 'applied', 'technical', 'research'] as const;
---

<Layout title="Learn — Zro2One" description="AI education at every depth level. Pick your level and start learning.">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-24">
    <div class="max-w-3xl mb-16">
      <h1 class="text-4xl sm:text-5xl font-black text-zro-dark mb-4">
        Learn AI
      </h1>
      <p class="text-xl text-zro-gray">
        Pick your depth level. Go at your own pace. Every article meets you where you are.
      </p>
    </div>

    <!-- Depth filter buttons -->
    <div class="flex flex-wrap gap-3 mb-12" id="depth-filters">
      <button
        data-depth="all"
        class="filter-btn active px-4 py-2 rounded-full text-sm font-medium border border-gray-300 bg-zro-dark text-white transition-colors"
      >
        All Levels
      </button>
      {depths.map(depth => (
        <button
          data-depth={depth}
          class="filter-btn px-4 py-2 rounded-full text-sm font-medium border border-gray-300 text-zro-gray hover:border-zro-dark hover:text-zro-dark transition-colors"
        >
          <DepthBadge depth={depth} size="sm" />
        </button>
      ))}
    </div>

    <!-- Articles grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6" id="articles-grid">
      {articles.map((article) => (
        <div data-depth={article.data.depth} class="article-item">
          <ArticleCard
            title={article.data.title}
            description={article.data.description}
            depth={article.data.depth}
            slug={article.id}
            readTime={article.data.readTime}
            pillar={article.data.pillar}
          />
        </div>
      ))}
    </div>

    {articles.length === 0 && (
      <div class="text-center py-20">
        <p class="text-xl text-zro-gray">Content coming soon! 🚀</p>
        <p class="text-sm text-zro-gray mt-2">We're building something amazing. Check back shortly.</p>
      </div>
    )}
  </div>
</Layout>

<script>
  const buttons = document.querySelectorAll('.filter-btn');
  const items = document.querySelectorAll('.article-item');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const depth = (btn as HTMLElement).dataset.depth;
      
      // Update active state
      buttons.forEach(b => {
        b.classList.remove('active', 'bg-zro-dark', 'text-white');
        b.classList.add('text-zro-gray', 'border-gray-300');
      });
      btn.classList.add('active', 'bg-zro-dark', 'text-white');
      btn.classList.remove('text-zro-gray', 'border-gray-300');

      // Filter articles
      items.forEach(item => {
        const el = item as HTMLElement;
        if (depth === 'all' || el.dataset.depth === depth) {
          el.style.display = '';
        } else {
          el.style.display = 'none';
        }
      });
    });
  });

  // Handle URL params
  const params = new URLSearchParams(window.location.search);
  const depthParam = params.get('depth');
  if (depthParam) {
    const btn = document.querySelector(`[data-depth="${depthParam}"]`) as HTMLElement;
    btn?.click();
  }
</script>
