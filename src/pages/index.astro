---
import Layout from '../layouts/Layout.astro';
import DepthBadge from '../components/DepthBadge.astro';
import NewsletterForm from '../components/NewsletterForm.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('learn', ({ data }) => !data.draft);
const featured = articles.slice(0, 6);
---

<Layout title="Zro2One — AI Education for Everyone">
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-zro-green/5 via-zro-blue/5 to-zro-purple/5"></div>
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-32 relative">
      <div class="max-w-3xl">
        <h1 class="text-4xl sm:text-6xl lg:text-7xl font-black tracking-tight text-zro-dark leading-[1.1]">
          AI literacy for<br />
          <span class="bg-gradient-to-r from-zro-green via-zro-blue to-zro-purple bg-clip-text text-transparent">
            all of humanity
          </span>
        </h1>
        <p class="mt-6 text-xl text-zro-gray leading-relaxed max-w-2xl">
          From "what is AI?" to frontier research — learn at the depth that's right for you. 
          No gatekeeping, no jargon walls. Just clear, practical AI education.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row gap-4">
          <a href="/learn" class="inline-flex items-center justify-center bg-zro-dark hover:bg-gray-800 text-white font-semibold rounded-lg px-6 py-3 transition-colors">
            Start Learning →
          </a>
          <a href="/about" class="inline-flex items-center justify-center border border-gray-300 hover:border-zro-dark text-zro-dark font-semibold rounded-lg px-6 py-3 transition-colors">
            Why Zro2One?
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Depth Levels Explained -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold text-zro-dark mb-4">
        One topic. Four depths.
      </h2>
      <p class="text-lg text-zro-gray max-w-2xl mx-auto">
        Every major AI concept is explained at the level that fits you — from plain-English essentials to cutting-edge research.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      <a href="/learn?depth=essential" class="block border-2 border-zro-green/30 rounded-xl p-6 hover:border-zro-green transition-colors">
        <div class="text-3xl mb-3">🟢</div>
        <h3 class="text-lg font-bold text-zro-dark mb-2">Essential</h3>
        <p class="text-sm text-zro-gray">For anyone curious about AI. Zero jargon, clear analogies, practical understanding.</p>
        <p class="text-xs text-zro-green-dark mt-3 font-medium">5 min reads · No prerequisites</p>
      </a>
      <a href="/learn?depth=applied" class="block border-2 border-zro-blue/30 rounded-xl p-6 hover:border-zro-blue transition-colors">
        <div class="text-3xl mb-3">🔵</div>
        <h3 class="text-lg font-bold text-zro-dark mb-2">Applied</h3>
        <p class="text-sm text-zro-gray">For professionals using AI at work. Practical guides, workflows, and real-world applications.</p>
        <p class="text-xs text-zro-blue-dark mt-3 font-medium">10 min reads · Some AI familiarity</p>
      </a>
      <a href="/learn?depth=technical" class="block border-2 border-zro-purple/30 rounded-xl p-6 hover:border-zro-purple transition-colors">
        <div class="text-3xl mb-3">🟣</div>
        <h3 class="text-lg font-bold text-zro-dark mb-2">Technical</h3>
        <p class="text-sm text-zro-gray">For developers and builders. Architecture deep-dives, code examples, implementation details.</p>
        <p class="text-xs text-zro-purple-dark mt-3 font-medium">15+ min reads · Technical background</p>
      </a>
      <a href="/learn?depth=research" class="block border-2 border-zro-red/30 rounded-xl p-6 hover:border-zro-red transition-colors">
        <div class="text-3xl mb-3">🔴</div>
        <h3 class="text-lg font-bold text-zro-dark mb-2">Research</h3>
        <p class="text-sm text-zro-gray">For researchers and advanced practitioners. Paper breakdowns, frontier concepts, open questions.</p>
        <p class="text-xs text-zro-red-dark mt-3 font-medium">20+ min reads · ML expertise</p>
      </a>
    </div>
  </section>

  <!-- Featured Content -->
  {featured.length > 0 && (
    <section class="bg-zro-light py-20">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between mb-12">
          <h2 class="text-3xl font-bold text-zro-dark">Latest Articles</h2>
          <a href="/learn" class="text-sm font-medium text-zro-blue hover:text-zro-blue-dark transition-colors">
            View all →
          </a>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {featured.map((article) => (
            <ArticleCard
              title={article.data.title}
              description={article.data.description}
              depth={article.data.depth}
              slug={article.id}
              readTime={article.data.readTime}
              pillar={article.data.pillar}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Flagship demo: How LLMs Work -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="text-center mb-12">
      <h2 class="text-3xl sm:text-4xl font-bold text-zro-dark mb-4">See it in action</h2>
      <p class="text-lg text-zro-gray max-w-2xl mx-auto">
        "How LLMs Work" — the same topic explained at every depth level. Pick where you are, and go.
      </p>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
      <a href="/learn/how-llms-work-essential" class="block border-2 border-zro-green/30 hover:border-zro-green rounded-xl p-5 transition-all hover:shadow-md group">
        <span class="text-sm font-medium text-zro-green-dark">🟢 Essential</span>
        <h3 class="font-bold text-zro-dark mt-2 group-hover:text-zro-green-dark transition-colors">How LLMs Work</h3>
        <p class="text-xs text-zro-gray mt-1">Plain English · 5 min</p>
      </a>
      <a href="/learn/how-llms-work-applied" class="block border-2 border-zro-blue/30 hover:border-zro-blue rounded-xl p-5 transition-all hover:shadow-md group">
        <span class="text-sm font-medium text-zro-blue-dark">🔵 Applied</span>
        <h3 class="font-bold text-zro-dark mt-2 group-hover:text-zro-blue-dark transition-colors">How LLMs Work</h3>
        <p class="text-xs text-zro-gray mt-1">Practical use · 10 min</p>
      </a>
      <a href="/learn/how-llms-work-technical" class="block border-2 border-zro-purple/30 hover:border-zro-purple rounded-xl p-5 transition-all hover:shadow-md group">
        <span class="text-sm font-medium text-zro-purple-dark">🟣 Technical</span>
        <h3 class="font-bold text-zro-dark mt-2 group-hover:text-zro-purple-dark transition-colors">How LLMs Work</h3>
        <p class="text-xs text-zro-gray mt-1">Under the hood · 15 min</p>
      </a>
      <a href="/learn/how-llms-work-research" class="block border-2 border-zro-red/30 hover:border-zro-red rounded-xl p-5 transition-all hover:shadow-md group">
        <span class="text-sm font-medium text-zro-red-dark">🔴 Research</span>
        <h3 class="font-bold text-zro-dark mt-2 group-hover:text-zro-red-dark transition-colors">How LLMs Work</h3>
        <p class="text-xs text-zro-gray mt-1">Frontier deep-dive · 20 min</p>
      </a>
    </div>
  </section>

  <!-- Start Here CTA -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="rounded-2xl border border-zro-blue/20 bg-zro-blue/5 p-8">
      <h2 class="text-2xl font-bold text-zro-dark">Not sure where to start?</h2>
      <p class="mt-2 text-zro-gray">Take the beginner path in 20 minutes.</p>
      <div class="mt-5 flex flex-wrap gap-3">
        <a href="/learn/what-is-ai" class="w-full sm:w-auto text-center px-4 py-2 rounded-lg bg-white border border-gray-300 text-sm font-medium">1) What is AI?</a>
        <a href="/learn/ai-glossary" class="w-full sm:w-auto text-center px-4 py-2 rounded-lg bg-white border border-gray-300 text-sm font-medium">2) AI Glossary</a>
        <a href="/learn/start-using-ai-today" class="w-full sm:w-auto text-center px-4 py-2 rounded-lg bg-white border border-gray-300 text-sm font-medium">3) Start Using AI Today</a>
      </div>
    </div>
  </section>

  <!-- Newsletter CTA -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <NewsletterForm />
  </section>
</Layout>
